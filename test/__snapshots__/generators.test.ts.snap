module('Acceptance | foo/bar-baz', function (hooks) {
  setupApplicationTest(hooks);

  test('it visits /foo/bar-baz', async function (assert) {
    await visit('/foo/bar-baz');

    assert.strictEqual(currentURL(), '/foo/bar-baz');
  });
});
"
`;


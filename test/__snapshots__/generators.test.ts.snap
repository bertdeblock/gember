import { setupRenderingTest } from 'v2-addon/tests/helpers';

module('Integration | Component | FooBarBaz', function (hooks) {
  setupRenderingTest(hooks);

  test('it renders', async function (assert) {
    await render(<template><FooBarBaz /></template>);

    assert.dom().hasText('');

    await render(
      <template>
        <FooBarBaz>
          template block text
        </FooBarBaz>
      </template>
    );

    assert.dom().hasText('template block text');
  });
});
"
`;

